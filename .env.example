# =============================================================================
# Hive v0 — environment configuration template
# Copy to .env and fill in secrets before running `hive up`.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider credentials
# -----------------------------------------------------------------------------

# Required for regions backed by Claude (Anthropic). See spec §F.4.
ANTHROPIC_API_KEY=

# Optional — only needed if any region is configured to use an OpenAI model.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# MQTT broker passwords (spec §B.8, §F.4, §G.1)
# Each region authenticates to the broker with its own username + password.
# Usernames are derived from the lowercase region name at broker-auth time
# (e.g. MQTT_PASSWORD_PREFRONTAL_CORTEX → username "prefrontal_cortex").
# These values are used by scripts/make_passwd.sh to generate bus/passwd.
# -----------------------------------------------------------------------------

MQTT_PASSWORD_MEDIAL_PREFRONTAL_CORTEX=
MQTT_PASSWORD_PREFRONTAL_CORTEX=
MQTT_PASSWORD_ANTERIOR_CINGULATE=
MQTT_PASSWORD_HIPPOCAMPUS=
MQTT_PASSWORD_THALAMUS=
MQTT_PASSWORD_ASSOCIATION_CORTEX=
MQTT_PASSWORD_INSULA=
MQTT_PASSWORD_BASAL_GANGLIA=
MQTT_PASSWORD_VISUAL_CORTEX=
MQTT_PASSWORD_AUDITORY_CORTEX=
MQTT_PASSWORD_MOTOR_CORTEX=
MQTT_PASSWORD_BROCA_AREA=
MQTT_PASSWORD_AMYGDALA=
MQTT_PASSWORD_VTA=

# Glia's broker password — glia manages the stack and needs its own auth slot.
MQTT_PASSWORD_GLIA=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# ed25519 public key used to verify human cosigned code-change approvals.
# Paste the full public key string here (spec §E.10).
# Example: ssh-ed25519 AAAA... user@host
HIVE_HUMAN_COSIGN_PUBKEY=

# -----------------------------------------------------------------------------
# Runtime behaviour
# -----------------------------------------------------------------------------

# Deployment environment: "dev" or "prod".
# hive up --dev is rejected when this is set to "prod" (spec §G.5).
HIVE_ENV=dev

# Log verbosity passed to all region containers.
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
HIVE_LOG_LEVEL=INFO
