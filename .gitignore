# Claude Code session artifacts
.claude/
.superpowers/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs / runtime
*.log
logs/
*.pid

# Hive-specific: region STM is ephemeral working memory, not version-controlled
regions/*/memory/stm.json

# Hive-specific: broker secrets and generated ACL (created at runtime)
bus/passwd
bus/acl.conf

# Environment variable overrides (local secrets, never committed)
.env

# Local docker-compose overrides (host-specific port remaps, etc.)
docker-compose.override.yaml
docker-compose.override.yml

# Local Phase 11 observation scratch (logs, probes, launcher scripts)
.pfc-obs/

# Test scratch directories
tests/**/_tmp_*

# Region LTM runtime notes (preserve the .gitkeep placeholder)
regions/*/memory/ltm/*
!regions/*/memory/ltm/.gitkeep

# Per-region git repos (nested repos, managed independently)
regions/*/.git/
